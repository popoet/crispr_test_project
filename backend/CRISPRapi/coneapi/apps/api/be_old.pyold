import os
import json
from django.conf import settings
from baseEditor import models as be_models
from cas9 import cas9 as cas9_module

# --- 辅助函数 ---
def parse_window(window_str):
    """解析类似 '14-17' 成 (14,17) 并验证 10<=start<=end<=20"""
    try:
        parts = window_str.split('-')
        start = int(parts[0])
        end = int(parts[1])
    except Exception:
        raise ValueError("Base editing window 格式错误，应为 'start-end'，例如 '14-17'")
    if start < 10 or end > 20 or start > end:
        raise ValueError("Base editing window 必须在 10 到 20 之间，且 start <= end")
    return start, end

# 标准遗传密码子表 (Standard Genetic Code)
CODON_TABLE = {
    # 第一个碱基：A
    'AAA': 'K', 'AAC': 'N', 'AAG': 'K', 'AAT': 'N',
    'ACA': 'T', 'ACC': 'T', 'ACG': 'T', 'ACT': 'T',
    'AGA': 'R', 'AGC': 'S', 'AGG': 'R', 'AGT': 'S',
    'ATA': 'I', 'ATC': 'I', 'ATG': 'M', 'ATT': 'I',

    # 第一个碱基：C
    'CAA': 'Q', 'CAC': 'H', 'CAG': 'Q', 'CAT': 'H',
    'CCA': 'P', 'CCC': 'P', 'CCG': 'P', 'CCT': 'P',
    'CGA': 'R', 'CGC': 'R', 'CGG': 'R', 'CGT': 'R',
    'CTA': 'L', 'CTC': 'L', 'CTG': 'L', 'CTT': 'L',

    # 第一个碱基：G
    'GAA': 'E', 'GAC': 'D', 'GAG': 'E', 'GAT': 'D',
    'GCA': 'A', 'GCC': 'A', 'GCG': 'A', 'GCT': 'A',
    'GGA': 'G', 'GGC': 'G', 'GGG': 'G', 'GGT': 'G',
    'GTA': 'V', 'GTC': 'V', 'GTG': 'V', 'GTT': 'V',

    # 第一个碱基：T
    'TAA': '*', 'TAC': 'Y', 'TAG': '*', 'TAT': 'Y',
    'TCA': 'S', 'TCC': 'S', 'TCG': 'S', 'TCT': 'S',
    'TGA': '*', 'TGC': 'C', 'TGG': 'W', 'TGT': 'C',
    'TTA': 'L', 'TTC': 'F', 'TTG': 'L', 'TTT': 'F'
}

# 氨基酸理化性质分类（按极性、电荷等）
AA_PROPERTIES = {
    # 非极性（疏水）氨基酸
    'A': 'nonpolar', 'I': 'nonpolar', 'L': 'nonpolar', 'M': 'nonpolar',
    'F': 'nonpolar', 'W': 'nonpolar', 'P': 'nonpolar', 'V': 'nonpolar', 'G': 'nonpolar',

    # 极性不带电荷（亲水）氨基酸
    'S': 'polar', 'T': 'polar', 'C': 'polar', 'Y': 'polar', 'N': 'polar', 'Q': 'polar',

    # 带正电荷（碱性）氨基酸
    'K': 'positive', 'R': 'positive', 'H': 'positive',

    # 带负电荷（酸性）氨基酸
    'D': 'negative', 'E': 'negative',

    # 终止密码子
    '*': 'stop'
}

def translate_dna(seq):
    """简单把 DNA 序列按三联子翻译到氨基酸（从第一个碱基开始），短 codon 返回 ''"""
    aa = []
    for i in range(0, len(seq) - 2, 3):
        codon = seq[i:i+3].upper().replace('U','T')
        aa.append(CODON_TABLE.get(codon, 'X'))
    return ''.join(aa)

def gc_content(seq):
    seq = seq.upper()
    if len(seq) == 0:
        return 0
    return round((seq.count('G') + seq.count('C'))/len(seq) * 100, 2)

