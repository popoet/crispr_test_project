def apply_base_edit(seq, editor_type, window_positions, pam_index_offset=0):
    """
    seq: 目标序列（通常是 spacer + PAM 上游之类的上下文，0-based）
    editor_type: 'ABE'/'CBE'/'GBE'/'ABE+CBE'
    window_positions: tuple (start_idx, end_idx) relative to sgRNA (1-based positions typical from user)
    返回：list of edits: 每个 edit 是 dict {pos, ref_base, alt_base, new_seq}
    说明：此函数只做本地替换，不做读框与修饰优先级判断。
    """
    # 增加防护性检查
    if seq is None or not isinstance(seq, str):
        return []

    # 验证序列是否为空
    if len(seq) == 0:
        return []

    start, end = window_positions
    # 将 1-based window 转换为 0-based indices 相对于 seq 的某个参照
    edits = []
    # 遍历 window 内碱基
    for i in range(start - 1, end):
        if i < 0 or i >= len(seq):
            continue
        base = seq[i].upper()
        alt = None
        if editor_type in ('ABE', 'ABE+CBE') and base == 'A':
            alt = 'G'
        if editor_type in ('CBE', 'ABE+CBE') and base == 'C':
            alt = 'T'
        # GBE: C -> G
        if editor_type == 'GBE' and base == 'C':
            alt = 'G'
        if alt:
            new_seq = seq[:i] + alt + seq[i + 1:]
            edits.append({"pos": i, "ref": base, "alt": alt, "new_seq": new_seq})
    return edits


